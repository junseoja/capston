# ============================================================
# Express 백엔드 환경변수 예시 파일 (.env.example)
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채우세요.
# .env 파일은 .gitignore에 의해 Git에 올라가지 않습니다.
# ============================================================

# Express 서버 포트 (기본값: 3000)
PORT=3000

# FastAPI 서버 URL (기본값: http://localhost:8000)
PYTHON_API=http://localhost:8000

# React 프론트엔드 URL - CORS 허용 대상 (기본값: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
